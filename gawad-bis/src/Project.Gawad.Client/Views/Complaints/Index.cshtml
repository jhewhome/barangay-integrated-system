@{
    ViewData["Title"] = "Complaints";
    ViewData["HeaderTitle"] = "Complaint Records";
}

@section StyleSheets
{
    <link rel="stylesheet" href="~/bootstrap-datatables/dataTables.bootstrap5.css" />
    <link rel="stylesheet" href="~/app/css/complaints.css?v=@DateTime.Now.Ticks" />
    <style>
        .table-responsive {
            border-radius: 0.375rem;
            overflow: hidden;
        }
        
        #tblMain {
            margin-bottom: 0;
        }
        
        #tblMain thead th {
            padding: 1rem 0.75rem;
            font-weight: 600;
            border-bottom: 2px solid #dee2e6;
        }
        
        #tblMain tbody td {
            padding: 0.5rem 0.5rem;
            vertical-align: middle;
        }
        
        #tblMain tbody tr:hover {
            background-color: rgba(0, 123, 255, 0.05);
        }
        
        .row-btn-view a, .row-btn-view button {
            color: #007bff;
            text-decoration: none;
            font-size: 1.2rem;
            background: none;
            border: none;
            padding: 0;
        }
        
        .row-btn-view a:hover, .row-btn-view button:hover {
            color: #0056b3;
        }
        
        .row-btn-update a {
            color: #ffc107;
            text-decoration: none;
            font-size: 1.2rem;
        }
        
        .row-btn-update a:hover {
            color: #e0a800;
        }
        
        .row-btn-view button.delete-complaint {
            color: #dc3545;
        }
        
        .row-btn-view button.delete-complaint:hover {
            color: #c82333;
        }
        
        /* DataTables pagination and controls spacing */
        .dataTables_wrapper .dataTables_paginate {
            margin-top: 2.5rem !important;
            margin-bottom: 1rem !important;
        }
        
        .dataTables_wrapper .dataTables_info {
            margin-top: 1.5rem !important;
            margin-bottom: 1rem !important;
        }
        
        .dataTables_wrapper .dataTables_length {
            margin-bottom: 1rem !important;
        }
        
        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 1rem !important;
        }
        
        .dataTables_wrapper .dt-buttons {
            margin-top: 2.5rem !important;
            margin-bottom: 1rem !important;
        }
        
        /* Card spacing improvements */
        .card-body {
            padding: 1.5rem;
        }
        
        .card-footer {
            padding: 1rem 1.5rem;
            background-color: #f8f9fa;
            border-top: 1px solid #dee2e6;
        }
        
        /* Button spacing in forms */
        .btn-group .btn {
            margin-right: 0.5rem;
        }
        
        .btn-group .btn:last-child {
            margin-right: 0;
        }
        
        /* Form spacing improvements */
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group:last-child {
            margin-bottom: 0;
        }
    </style>
}

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script src="~/bootstrap-datatables/dataTables.js"></script>
    <script src="~/bootstrap-datatables/dataTables.bootstrap5.js"></script>
    <script src="~/bootstrap-datatables/dataTables.buttons.js"></script>
    <script src="~/bootstrap-datatables/buttons.dataTables.js"></script>
    <script src="~/bootstrap-datatables/jszip.min.js"></script>
    <script src="~/bootstrap-datatables/pdfmake.min.js"></script>
    <script src="~/bootstrap-datatables/vfs_fonts.js"></script>
    <script src="~/bootstrap-datatables/buttons.html5.min.js"></script>
    <script src="~/bootstrap-datatables/buttons.print.min.js"></script>
        <script src="~/app/js/complaints-index.js?v=@DateTime.UtcNow.Ticks"></script>
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="row g-2">
                <div class="col-md-10">
                    <h3 class="card-title">@ViewData["HeaderTitle"]</h3>
                </div>
                <div class="col-md-2 text-end">
                    <a asp-action="FileComplaint" class="btn btn-success">
                        <i class="bi bi-file-earmark-text-fill"></i> Add Complaint
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <form id="__antiForgeryForm" method="post">
                @Html.AntiForgeryToken()
            </form>
            <table id="tblMain" class="table table-striped complaint-table" style="width:100%"></table>
        </div>
    </div>
</div>

<!-- Complaint Details Modal -->
@await Html.PartialAsync("_ComplaintDetailsModal", new Project.Gawad.Domain.Objects.Complaint.ComplaintFormObject())

