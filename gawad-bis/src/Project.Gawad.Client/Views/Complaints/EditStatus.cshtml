@model Project.Gawad.Domain.Objects.Complaint.ComplaintFormObject
@{
    ViewData["Title"] = "Edit Complaint Status";
    ViewData["HeaderTitle"] = "Edit Complaint Status";
}

@section StyleSheets
{
    <link rel="stylesheet" href="~/app/css/complaints.css" />
    <style>
        .card {
            margin-bottom: 2rem;
        }
        
        .card-body {
            padding: 2rem;
        }
        
        .card-header {
            padding: 1rem 2rem;
            background-color: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }
        
        .card-title {
            margin-bottom: 0;
            font-weight: 600;
        }
        
        .form-group {
            margin-bottom: 2rem;
        }
        
        .form-group:last-child {
            margin-bottom: 0;
        }
        
        .form-control {
            margin-top: 0.5rem;
        }
        
        .btn {
            margin-right: 0.75rem;
        }
        
        .btn:last-child {
            margin-right: 0;
        }
        
        .badge {
            font-size: 0.875rem;
            padding: 0.5rem 0.75rem;
        }
        
        hr {
            margin: 2rem 0;
            border-color: #dee2e6;
        }
        
        h5 {
            margin-bottom: 1rem;
            font-weight: 600;
            color: #495057;
        }
        
        p {
            margin-bottom: 0.75rem;
        }
        
        p:last-child {
            margin-bottom: 0;
        }
    </style>
}

<div class="row">
    <div class="col-12">
        <div class="card card-primary card-outline complaint-card">
            <div class="card-header">
                <h3 class="card-title">@ViewData["HeaderTitle"]</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h5>Complaint Details</h5>
                        <p><strong>Subject:</strong> @Model.Subject</p>
                        <p><strong>Current Status:</strong> <span class="badge badge-info">@Model.Status</span></p>
                        <p><strong>Type:</strong> @Model.ComplaintType</p>
                        <p><strong>Incident Date:</strong> @Model.IncidentDateTime?.ToString("MMM dd, yyyy")</p>
                    </div>
                    <div class="col-md-6">
                        <h5>Complainant</h5>
                        @if (Model.Complainants?.Any() == true)
                        {
                            var complainant = Model.Complainants.First();
                            <p><strong>Name:</strong> @complainant.FirstName @complainant.LastName</p>
                        }
                    </div>
                </div>

                <hr />

                <form action="/Complaints/EditStatus/@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="form-group">
                        <label class="control-label">New Status</label>
                        <select name="newStatus" class="form-control">
                            @foreach (var status in Enum.GetValues<Project.Gawad.Domain.Enums.Complaints.ComplaintStatus>())
                            {
                                <option value="@((int)status)" selected="@(Model.Status == status)">
                                    @status.ToString()
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary btn-spacing">
                            <i class="bi bi-check-circle"></i> Update Status
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('form').on('submit', function(e) {
                var formData = $(this).serialize();
                console.log('Form data being submitted:', formData);
                console.log('ID value:', $('input[name="id"]').val());
                console.log('Status value:', $('select[name="newStatus"]').val());
            });
        });
    </script>
}
