                @Html.ValidationMessageFor(m => m.Complainants[0].DateOfBirth, "", new { @class = "text-danger" })
            </div>
            <div class="col-md-3">
                @Html.LabelFor(m => m.Complainants[0].Gender, "Gender", new { @class = "form-label" })
                @Html.DropDownListFor(m => m.Complainants[0].Gender, new SelectList(Enum.GetValues(typeof(Project.Gawad.Domain.Enums.Gender))), "Select Gender", new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Complainants[0].Gender, "", new { @class = "text-danger" })
            </div>
                </div>
                <div class="row g-3 mt-2">
                    <div class="col-md-3">
                        @Html.LabelFor(m => m.Complainants[0].CivilStatus, "Civil Status", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.Complainants[0].CivilStatus, new SelectList(Enum.GetValues(typeof(Project.Gawad.Domain.Enums.CivilStatus))), "Select Civil Status", new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Complainants[0].CivilStatus, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-3">
                        @Html.LabelFor(m => m.Complainants[0].CompAddressLine1, "Address Line 1", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Complainants[0].CompAddressLine1, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Complainants[0].CompAddressLine1, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-2">
                        @Html.LabelFor(m => m.Complainants[0].CompAddBarangay, "Barangay", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Complainants[0].CompAddBarangay, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Complainants[0].CompAddBarangay, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-2">
                        @Html.LabelFor(m => m.Complainants[0].CompAddCity, "City", new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Complainants[0].CompAddCity, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Complainants[0].CompAddCity, "", new { @class = "text-danger" })
                    </div>
