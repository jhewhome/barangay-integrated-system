@using Project.Gawad.Client.Extensions
@using MongoDB.Bson
@using Project.Gawad.Domain.Enums
@using Project.Gawad.Domain.Enums.Complaints
@model Project.Gawad.Domain.Objects.Complaint.ComplaintFormObject

@{
    ViewData["Title"] = "Complaints";
    ViewData["HeaderTitle"] = "Formal Complaint Form";
}

@section StyleSheets
{
    <link rel="stylesheet" href="~/select2/select2.min.css" />
    <link rel="stylesheet" href="~/select2/select2-bootstrap4.min.css" />
    <link rel="stylesheet" href="~/app/css/app.css" />
    <link rel="stylesheet" href="~/app/css/complaints.css" />
    <style>
        .validation-message {
            display: block;
            margin-top: 0.25rem;
            font-size: 0.875rem;
            color: #dc3545;
        }
        .form-control.is-invalid {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.25);
        }
        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
        
        /* Form spacing improvements */
        .card {
            margin-bottom: 2rem;
        }
        
        .card:last-child {
            margin-bottom: 0;
        }
        
        .card-body {
            padding: 1.5rem;
        }
        
        .card-footer {
            padding: 1.5rem;
            background-color: #f8f9fa;
            border-top: 1px solid #dee2e6;
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group:last-child {
            margin-bottom: 0;
        }
        
        .row.g-3 {
            margin-bottom: 1rem;
        }
        
        .row.g-3:last-child {
            margin-bottom: 0;
        }
        
        /* Button spacing */
        .btn-group .btn {
            margin-right: 0.75rem;
        }
        
        .btn-group .btn:last-child {
            margin-right: 0;
        }
        
        /* Form label spacing */
        .form-label {
            margin-bottom: 0.5rem;
            font-weight: 600;
        }
        
        /* Card header improvements */
        .card-header {
            padding: 1rem 1.5rem;
            background-color: #f8f9fa;
            border-bottom: 1px solid #dee2e6;
        }
        
        .card-title {
            margin-bottom: 0;
            font-weight: 600;
        }
        
        /* Section spacing */
        .row {
            margin-bottom: 1rem;
        }
        
        .row:last-child {
            margin-bottom: 0;
        }
    </style>
}

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script src="~/bootstrap-datatables/dataTables.js"></script>
    <script src="~/bootstrap-datatables/dataTables.bootstrap5.js"></script>
    <script src="~/moment/moment.min.js"></script>
    <script src="~/select2/select2.full.min.js"></script>
    <script src="~/bootstrap-daterangepicker/daterangepicker.js"></script>
    <script src="~/app/js/transactions-applybusinesspermit.js"></script>
    <script src="~/app/js/person-finder.js"></script>
    <script src="~/app/js/complaint-form.js"></script>
    
    @* Simple form validation - using server-side validation with proper model binding *@
    <script>
        $(function () {
            // Simple client-side validation for better UX
            $('form').on('submit', function() {
                var isValid = true;
                
                // Check required fields
                $('input[required], select[required]').each(function() {
                    if (!$(this).val()) {
                        $(this).addClass('is-invalid');
                        isValid = false;
                    } else {
                        $(this).removeClass('is-invalid');
                    }
                });
                
                if (!isValid) {
                    alert('Please fill in all required fields.');
                    return false;
                }
                
                // Show loading state
                $('button[type="submit"]').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Submitting...');
            });
        });
    </script>
}

@section NavigationCrumbs
{
    <ol class="breadcrumb float-sm-end">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Complaints">Complaints</a></li>
        <li class="breadcrumb-item active" aria-current="page">@ViewData["HeaderTitle"]</li>
    </ol>
}

