                <!--end::Body-->
                <!--begin::Footer-->
                <div class="card-footer">
                    <div class="row">
                        <div class="col-md-10">

                        </div>
                        <div class="col-md-1">
                            <a class="btn btn-lg btn-danger" href="@Url.Action("Index", "Residents")">Cancel</a>
                        </div>
                        <div class="col-md-1">
                            <button class="btn btn-lg btn-success" type="submit">Submit</button>
                        </div>
                    </div>
                </div>
                <!--end::Footer-->

            </div>
