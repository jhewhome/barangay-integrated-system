                        </div>

                        <div class="col-md-3">
                            @Html.LabelFor(model => model.PermAddCity, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.PermAddCity, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.PermAddCity, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-3">
                            @Html.LabelFor(model => model.PermAddProvince, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.PermAddProvince, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.PermAddProvince, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-1">
                            @Html.LabelFor(model => model.PermAddZipCode, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.PermAddZipCode, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.PermAddZipCode, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-3">
                            @Html.LabelFor(model => model.PermAddCountry, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.PermAddCountry, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.PermAddCountry, "", new { @class = "form-text field-validation-error" })
                        </div>
                    </div>
                    <!--end::Row-->
                </div>
                <!--end::Body-->
            </div>
        </div>

        <div class="row">
            <div class="card card-info card-outline mb-3">
                <!--begin::Header-->
                <div class="card-header">
                    <div class="card-title"><i class="bi bi-pin-map-fill"></i> Current Address</div>
                </div>
                <!--end::Header-->
                <!--begin::Body-->
                <div class="card-body">
                    <!--begin::Row-->
                    <div class="row g-3">
                        <div class="col-md-5">
                            @Html.LabelFor(model => model.CurrAddAddressLine1, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddAddressLine1, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddAddressLine1, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-5">
                            @Html.LabelFor(model => model.CurrAddAddressLine2, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddAddressLine2, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddAddressLine2, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-2">
                            @Html.LabelFor(model => model.CurrAddZone, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddZone, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddZone, "", new { @class = "form-text field-validation-error" })
                        </div>

                        <div class="col-md-2">
                            @Html.LabelFor(model => model.CurrAddBarangay, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddBarangay, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddBarangay, "", new { @class = "form-text field-validation-error" })
                        </div>

                        <div class="col-md-3">
                            @Html.LabelFor(model => model.CurrAddCity, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddCity, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddCity, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-3">
                            @Html.LabelFor(model => model.CurrAddProvince, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddProvince, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddProvince, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-1">
                            @Html.LabelFor(model => model.CurrAddZipCode, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddZipCode, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddZipCode, "", new { @class = "form-text field-validation-error" })
                        </div>
                        <div class="col-md-3">
                            @Html.LabelFor(model => model.CurrAddCountry, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.CurrAddCountry, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.CurrAddCountry, "", new { @class = "form-text field-validation-error" })
                        </div>
                    </div>
                    <!--end::Row-->
                </div>
                <!--end::Body-->
            </div>
        </div>

        <div class="row">
            <div class="card card-danger card-outline mb-3">
                <!--begin::Header-->
                <div class="card-header">
                    <div class="card-title"><i class="bi bi-credit-card-2-front-fill"></i> Voter Details</div>
                </div>
                <!--end::Header-->
                <!--begin::Body-->
                <div class="card-body">
                    <!--begin::Row-->
                    <div class="row g-3">
                        <div class="col-md-3" style="display: flex; align-items: center; ">
                            <div class="form-check">
                                @Html.LabelFor(model => model.IsRegisteredVoter, new { @class = "form-check-label", style = "vertical-align: middle;" })
                                @Html.CheckBoxFor(model => model.IsRegisteredVoter, new { @class = "form-check-input form-control-sm" })
                                @Html.ValidationMessageFor(model => model.IsRegisteredVoter, "", new { @class = "form-text field-validation-error" })
                            </div>
                        </div>
                    </div>
                    <div class="row g-3">

                        <div class="col-md-3">
                            @Html.LabelFor(model => model.VoterId, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.VoterId, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.VoterId, "", new { @class = "form-text field-validation-error" })
                        </div>

                        <div class="col-md-3">
                            @Html.LabelFor(model => model.PrecintNo, new { @class = "form-label" })
                            @Html.TextBoxFor(model => model.PrecintNo, new { @class = "form-control", placeholder = "" })
                            @Html.ValidationMessageFor(model => model.PrecintNo, "", new { @class = "form-text field-validation-error" })
                        </div>
                    </div>
                    <!--end::Row-->
