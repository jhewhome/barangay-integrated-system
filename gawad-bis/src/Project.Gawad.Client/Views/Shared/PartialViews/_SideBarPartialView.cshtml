@using System.Security.Claims
@using Microsoft.Extensions.Options
@using Project.Gawad.Application.Options
@using Project.Gawad.Core.Services
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@inject IOptions<AppConfigOption> AppConfigOption
@inject IOptions<BhcIntegrationOption> BhcIntegrationOption
@inject IBhcSsoLinkService BhcSsoLink
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var area = ViewContext.RouteData.Values["area"]?.ToString();
    var bhc = BhcIntegrationOption.Value;
    var bhcOpenInNewTab = bhc.OpenInNewTab ? "_blank" : null;
    var bhcRel = bhc.OpenInNewTab ? "noopener noreferrer" : null;
    var bhcUsername = HttpContextAccessor.HttpContext?.User?.Identity?.Name;
    var bhcRole = HttpContextAccessor.HttpContext?.User?.FindFirst(ClaimTypes.Role)?.Value;
    
    // Helper function to check if a controller/action is active
    bool IsActive(string controllerName, string actionName = "Index")
    {
        return controller?.Equals(controllerName, StringComparison.OrdinalIgnoreCase) == true 
            && action?.Equals(actionName, StringComparison.OrdinalIgnoreCase) == true;
    }
    
    // Helper function to check if any action in a controller is active
    bool IsControllerActive(string controllerName)
    {
        return controller?.Equals(controllerName, StringComparison.OrdinalIgnoreCase) == true;
    }

    string? BhcUrl(string path) => BhcSsoLink.BuildLink(path, bhcUsername, bhcRole);
}

