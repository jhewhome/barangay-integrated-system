@{
    ViewData["Title"] = "Access Management";
    ViewData["HeaderTitle"] = "System Users";
}

@section StyleSheets
{
    <link type="text/css" rel="stylesheet" href="../bootstrap-datatables/dataTables.bootstrap5.css"/>
    <link rel="stylesheet" href="~/app/css/complaints.css" />
}

@section Scripts
{
    <script src="../bootstrap-datatables/jquery-3.7.1.js"></script>
    <script src="../bootstrap-datatables/dataTables.js"></script>
    <script src="../bootstrap-datatables/dataTables.bootstrap5.js"></script>
    <script src="../bootstrap-datatables/dataTables.buttons.js"></script>
    <script src="../bootstrap-datatables/buttons.dataTables.js"></script>
    <script src="../bootstrap-datatables/jszip.min.js"></script>
    <script src="../bootstrap-datatables/pdfmake.min.js"></script>
    <script src="../bootstrap-datatables/vfs_fonts.js"></script>
    <script src="../bootstrap-datatables/buttons.html5.min.js"></script>
    <script src="../bootstrap-datatables/buttons.print.min.js"></script>
    <script src="../moment.js"></script>
    <script src="../app/js/users-index.js"></script>
}

@section NavigationCrumbs
{

}


<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="row g-2">
                <div class="col-md-10">
                    <h3 class="card-title"></h3>
                </div>
                <div class="col-md-2">
                    <a href="@Url.ActionLink("AddUser", "UserManagement")" class="btn btn-success"><i
                            class="bi bi-person-plus-fill"></i> Add New User</a>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <table id="tblMain" class="table table-striped complaint-table" style="width:100%"></table>
        </div>
    </div>
</div>