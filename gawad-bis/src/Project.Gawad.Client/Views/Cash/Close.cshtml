@model Project.Gawad.Domain.Objects.Cash.CloseCashSessionObject
@{
    ViewData["Title"] = "Close Cash Session";
    ViewData["HeaderTitle"] = "Close Cash Session";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">Close Cash Session</h3>
        </div>
        <form asp-action="Close" method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="SessionId" />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ClosingAmount"></label>
                            <input asp-for="ClosingAmount" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="ClosingAmount" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ClosingNotes"></label>
                            <input asp-for="ClosingNotes" class="form-control" />
                            <span asp-validation-for="ClosingNotes" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-danger">Close Session</button>
                <a href="@Url.Action("Dashboard")" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    
</div>





