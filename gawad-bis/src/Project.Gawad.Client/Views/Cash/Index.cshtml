@model Project.Gawad.Domain.Objects.PaginatedRecords<Project.Gawad.Domain.Objects.Cash.CashSessionListObject>
@{
    ViewData["Title"] = "Cash Sessions";
    ViewData["HeaderTitle"] = "Cash Sessions";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="row g-2 align-items-center">
                <div class="col-lg-8 col-md-6">
                    <h3 class="card-title">Cash Sessions</h3>
                </div>
                <div class="col-lg-4 col-md-6 d-flex gap-2 justify-content-end">
                    <a href="@Url.ActionLink("Dashboard")" class="btn btn-info">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (Model == null || !Model.Data.Any())
            {
                <div class="alert alert-info mb-0">No cash sessions found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Opened By</th>
                                <th class="text-end">Opening Float</th>
                                <th class="text-end">Total Sales</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var session in Model.Data)
                        {
                            <tr>
                                <td>@session.SessionDate.ToString("MM/dd/yyyy")</td>
                                <td>@session.OpenedByName</td>
                                <td class="text-end">@session.OpeningFloat.ToString("F2")</td>
                                <td class="text-end">@session.TotalSales.ToString("F2")</td>
                                <td>
                                    <span class="badge bg-@(session.Status == Project.Gawad.Domain.Enums.Cash.CashSessionStatus.Open ? "success" : "secondary")">
                                        @session.StatusName
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = session.Id })" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>



