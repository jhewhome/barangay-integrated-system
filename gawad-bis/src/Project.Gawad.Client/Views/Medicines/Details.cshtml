@model Project.Gawad.Domain.Objects.Medicine.MedicineDetailObject
@{
    ViewData["Title"] = "Medicine Details";
    ViewData["HeaderTitle"] = "Medicine Details";
}

@functions {
    // Helper function to parse unit type and count from Notes field
    string GetUnitTypeAndCount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        if (string.IsNullOrWhiteSpace(transaction.Notes))
            return null;

        var notes = transaction.Notes.Trim();
        
        // Check for INPUT_UNIT format: "INPUT_UNIT:boxes:2" or "INPUT_UNIT:bottles:5"
        if (notes.StartsWith("INPUT_UNIT:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var unitInfo = notes.Substring(11); // Remove "INPUT_UNIT:" prefix
                var unitInfoPart = unitInfo.Split(';')[0].Trim(); // Get first part if there are multiple sections
                var parts = unitInfoPart.Split(':');
                
                if (parts.Length >= 2)
                {
                    var unitType = parts[0].Trim().ToLower();
                    if (decimal.TryParse(parts[1].Trim(), out var unitCount) && unitCount > 0)
                    {
                        // Normalize unit type names
                        if (unitType == "boxes" || unitType == "box")
                            return $"{unitCount} box{(unitCount != 1 ? "es" : "")}";
                        else if (unitType == "bottles" || unitType == "bottle")
                            return $"{unitCount} bottle{(unitCount != 1 ? "s" : "")}";
                        else if (unitType == "pieces" || unitType == "piece")
                            return $"{unitCount} piece{(unitCount != 1 ? "s" : "")}";
                    }
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        // Check for BOXES format: "BOXES:2.5" (used in dispensed transactions)
        if (notes.StartsWith("BOXES:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var boxesStr = notes.Substring(6).Trim(); // Remove "BOXES:" prefix
                var boxInfoPart = boxesStr.Split(';')[0].Trim(); // Get first part if there are multiple sections
                if (decimal.TryParse(boxInfoPart, out var numberOfBoxes) && numberOfBoxes > 0)
                {
                    return $"{numberOfBoxes} box{(numberOfBoxes != 1 ? "es" : "")}";
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        return null;
    }
    
    // Helper function to calculate total amount correctly
    // Formula: Unit Price × Number of Boxes/Bottles (NOT quantity/pieces)
    decimal? GetCalculatedTotalAmount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        // If TotalAmount already exists, use it
        if (transaction.TotalAmount.HasValue)
            return transaction.TotalAmount;
        
        // If no unit price, can't calculate
        if (!transaction.UnitPrice.HasValue)
            return null;
        
        // Parse Notes to get unit type and count
        var unitTypeAndCount = GetUnitTypeAndCount(transaction);
        if (string.IsNullOrWhiteSpace(unitTypeAndCount))
            return null; // Can't calculate without unit info
        
        // Extract number from unitTypeAndCount (e.g., "2 boxes" -> 2)
        try
        {
            var parts = unitTypeAndCount.Split(' ');
            if (parts.Length >= 1 && decimal.TryParse(parts[0], out var unitCount))
            {
                // Formula: Unit Price × Number of Boxes/Bottles
                return transaction.UnitPrice.Value * unitCount;
            }
        }
        catch
        {
            // If parsing fails, return null
        }
        
        return null;
    }
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">@Model.Name</h3>
            <div class="card-tools">
                <a href="@Url.Action("MedicineReport", new { id = Model.Id })" class="btn btn-sm btn-info">
                    <i class="bi bi-file-earmark-text"></i> Generate Report
                </a>
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-sm btn-warning">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="@Url.Action("AddStock", new { medicineId = Model.Id })" class="btn btn-sm btn-success">
                    <i class="bi bi-plus"></i> Add Stock
                </a>
            </div>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name:</dt>
                <dd class="col-sm-9">@Model.Name</dd>
                
                <dt class="col-sm-3">Category:</dt>
                <dd class="col-sm-9">@Model.CategoryName</dd>
                
                <dt class="col-sm-3">Current Stock:</dt>
                <dd class="col-sm-9">@Model.TotalStock</dd>
                
                <dt class="col-sm-3">Minimum Stock Level:</dt>
                <dd class="col-sm-9">@Model.MinimumStockLevel</dd>
            </dl>
        </div>
    </div>
</div>

@* Transaction Statistics Summary *@
@if (ViewBag.TotalTransactions != null && (int)ViewBag.TotalTransactions > 0)
{
    <div class="col-12 mt-3">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="bi bi-graph-up"></i> Transaction Summary
                </h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="card-title mb-1">Total Dispensed</h6>
                                        <h3 class="mb-0">@(ViewBag.TotalDispensed ?? 0)</h3>
                                    </div>
                                    <div>
                                        <i class="bi bi-box-arrow-up" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card bg-success text-white">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="card-title mb-1">Total Stock In</h6>
                                        <h3 class="mb-0">@(ViewBag.TotalStockIn ?? 0)</h3>
                                    </div>
                                    <div>
                                        <i class="bi bi-box-arrow-down" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card bg-warning text-white">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="card-title mb-1">Total Stock Out</h6>
                                        <h3 class="mb-0">@(ViewBag.TotalStockOut ?? 0)</h3>
                                    </div>
                                    <div>
                                        <i class="bi bi-box-arrow-right" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card bg-info text-white">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="card-title mb-1">Total Value</h6>
                                        <h3 class="mb-0">@(((decimal)(ViewBag.TotalDispensedValue ?? 0)).ToString("N0"))</h3>
                                    </div>
                                    <div>
                                        <i class="bi bi-cash-coin" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-md-12">
                        <div class="alert alert-info mb-0 d-flex justify-content-between align-items-center">
                            <div>
                                <strong>Total Transactions:</strong> @(ViewBag.TotalTransactions ?? 0) | 
                                <strong>Dispensed Transactions:</strong> @(ViewBag.DispensedCount ?? 0)
                            </div>
                            <a href="@Url.Action("Transactions", new { medicineId = Model.Id })" class="btn btn-sm btn-primary">
                                <i class="bi bi-list-ul"></i> View Detailed Transaction Report
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (ViewBag.RecentTransactions != null)
{
    var recentTransactions = (List<Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject>)ViewBag.RecentTransactions;
    var totalTransactions = ViewBag.TotalTransactions ?? 0;

    <div class="col-12 mt-3">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="card-title">
                        <i class="bi bi-clock-history"></i> Transaction History
                    </h3>
                    <a href="@Url.Action("Transactions", new { medicineId = Model.Id })" class="btn btn-sm btn-primary">
                        <i class="bi bi-arrow-right"></i> View All Transactions (@totalTransactions)
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (recentTransactions != null && recentTransactions.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Total</th>
                                    <th>Recipient</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in recentTransactions)
                                {
                                    var unitTypeAndCount = GetUnitTypeAndCount(t);
                                    <tr>
                                        <td>@t.TransactionDate.ToString("MM/dd/yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge bg-@(t.TransactionType == Project.Gawad.Domain.Enums.Medicine.MedicineTransactionType.Dispensed ? "warning" : "success")">
                                                @t.TransactionTypeName
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            @if (!string.IsNullOrEmpty(unitTypeAndCount))
                                            {
                                                <div>@unitTypeAndCount</div>
                                                <small class="text-muted">(@t.Quantity.ToString("N0") pieces)</small>
                                            }
                                            else
                                            {
                                                @t.Quantity.ToString("N0") <small class="text-muted">pieces</small>
                                            }
                                        </td>
                                        <td class="text-end">@(t.UnitPrice.HasValue ? t.UnitPrice.Value.ToString("N2") : "-")</td>
                                        <td class="text-end">
                                            @{
                                                var calculatedTotal = GetCalculatedTotalAmount(t);
                                                if (calculatedTotal.HasValue)
                                                {
                                                    <text>@calculatedTotal.Value.ToString("N2")</text>
                                                }
                                                else
                                                {
                                                    <text>-</text>
                                                }
                                            }
                                        </td>
                                        <td>@(t.RecipientName ?? "-")</td>
                                        <td class="text-end">
                                            @if (t.TransactionType == Project.Gawad.Domain.Enums.Medicine.MedicineTransactionType.Dispensed)
                                            {
                                                <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Receipt", new { id = t.Id })" title="View Receipt">
                                                    <i class="bi bi-receipt"></i>
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> No transactions found for this medicine yet.
                    </div>
                }
            </div>
        </div>
    </div>
}




