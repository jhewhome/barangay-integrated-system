@model Project.Gawad.Domain.Objects.PaginatedRecords<Project.Gawad.Domain.Objects.Medicine.AuditLogListObject>
@{
    ViewData["Title"] = "Audit Log";
    ViewData["HeaderTitle"] = "User Activity Audit Log";
    var filter = ViewBag.Filter as Project.Gawad.Domain.Objects.Medicine.AuditLogFilterObject;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var itemsPerPage = ViewBag.ItemsPerPage as int? ?? 50;
}

@section StyleSheets
{
    <link type="text/css" rel="stylesheet" href="~/select2/select2.min.css"/>
    <link type="text/css" rel="stylesheet" href="~/select2/select2-bootstrap4.min.css"/>
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">User Activity Audit Log</h3>
            <div class="card-tools">
                <small class="text-muted">Note: Audit logs are created for actions performed after the audit system was enabled. Historical actions are not logged.</small>
            </div>
        </div>
        <div class="card-body">
            <!-- Filter Form -->
            <form method="get" action="@Url.Action("AuditLog")" class="row g-3 mb-3">
                <div class="col-md-3">
                    <label for="action" class="form-label">Action</label>
                    <select id="action" name="action" class="form-control">
                        <option value="">All Actions</option>
                        <option value="Create" selected="@(filter?.Action == "Create")">Create</option>
                        <option value="Update" selected="@(filter?.Action == "Update")">Update</option>
                        <option value="Delete" selected="@(filter?.Action == "Delete")">Delete</option>
                        <option value="StockIn" selected="@(filter?.Action == "StockIn")">Stock In</option>
                        <option value="Dispensed" selected="@(filter?.Action == "Dispensed")">Dispensed</option>
                        <option value="Adjust" selected="@(filter?.Action == "Adjust")">Adjust</option>
                        <option value="Discard" selected="@(filter?.Action == "Discard")">Discard</option>
                        <option value="ReportExport" selected="@(filter?.Action == "ReportExport")">Report Export</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="entity" class="form-label">Entity</label>
                    <select id="entity" name="entity" class="form-control">
                        <option value="">All Entities</option>
                        <option value="Medicine" selected="@(filter?.Entity == "Medicine")">Medicine (Create/Update/Delete)</option>
                        <option value="MedicineStock" selected="@(filter?.Entity == "MedicineStock")">Medicine Stock (Stock In)</option>
                        <option value="MedicineTransaction" selected="@(filter?.Entity == "MedicineTransaction")">Medicine Transaction (Dispensed/Delete Transaction)</option>
                        <option value="Report" selected="@(filter?.Entity == "Report")">Report</option>
                    </select>
                    <small class="form-text text-muted">Note: Dispensed actions use "Medicine Transaction" entity</small>
                </div>
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Start Date (Optional)</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" value="@(filter?.StartDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">End Date (Optional)</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" value="@(filter?.EndDate?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-6">
                    <label for="userName" class="form-label">User Name</label>
                    <select id="userName" name="userName" class="form-control select2bs4" style="width: 100%;" data-placeholder="Type to search user name...">
                        @if (!string.IsNullOrWhiteSpace(filter?.UserName))
                        {
                            <option value="@filter.UserName" selected>@filter.UserName</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">&nbsp;</label>
                    <div>
                        <button type="submit" class="btn btn-primary">Apply Filters</button>
                        <a href="@Url.Action("AuditLog")" class="btn btn-secondary">Clear Filters</a>
                    </div>
                </div>
            </form>

            <!-- Debug Info -->
            @{
                var totalRecords = ViewBag.TotalRecords as int? ?? 0;
            }
            @if (totalRecords > 0 && (Model?.Data == null || !Model.Data.Any()))
            {
                <div class="alert alert-warning mb-3">
                    <small>Found <strong>@totalRecords</strong> total record(s) but none on this page. Try navigating to other pages.</small>
                </div>
            }
            else if (totalRecords > 0)
            {
                <div class="alert alert-success mb-3">
                    <small>Found <strong>@totalRecords</strong> audit log entry(ies) matching your filters.</small>
                </div>
            }

            <!-- Helpful tip for Dispensed actions -->
            @if (!string.IsNullOrWhiteSpace(filter?.Action) && filter.Action == "Dispensed" && filter.Entity == "Medicine")
            {
                <div class="alert alert-warning mb-3">
                    <strong>Tip:</strong> Dispensed actions are logged with entity type <strong>"Medicine Transaction"</strong>, not "Medicine". 
                    Please change the Entity filter to <strong>"Medicine Transaction"</strong> to see dispensed actions.
                </div>
            }

            <!-- Audit Log Table -->
            @if (Model?.Data == null || !Model.Data.Any())
            {
                <div class="alert alert-info">
                    <strong>No audit log entries found.</strong><br/>
                    @if (filter?.StartDate.HasValue == true || filter?.EndDate.HasValue == true || !string.IsNullOrWhiteSpace(filter?.Action) || !string.IsNullOrWhiteSpace(filter?.Entity) || !string.IsNullOrWhiteSpace(filter?.UserName))
                    {
                        <span>Try adjusting your filters or <a href="@Url.Action("AuditLog")" class="alert-link">clear all filters</a> to see all entries.</span>
                        <br/><small>Total records in database: @totalRecords</small>
                        @if (filter?.Action == "Dispensed" && filter?.Entity == "Medicine")
                        {
                            <br/>
                            <text><strong>Note:</strong> Dispensed actions use entity type "Medicine Transaction", not "Medicine". Please change the Entity filter to "Medicine Transaction".</text>
                        }
                    }
                    else
                    {
                        <span>Audit logs are created when users perform actions like creating medicines, adding stock, dispensing, etc. Perform some actions to generate audit log entries.</span>
                        <br/><small>Total records in database: @totalRecords</small>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Date & Time</th>
                                <th>Action</th>
                                <th>Entity</th>
                                <th>User</th>
                                <th>Role</th>
                                <th>IP Address</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model.Data)
                            {
                                <tr>
                                    <td>@log.CreatedDate.ToString("MM/dd/yyyy HH:mm:ss")</td>
                                    <td><span class="badge bg-info">@log.Action</span></td>
                                    <td>@log.Entity</td>
                                    <td>@(log.UserName ?? "Unknown")</td>
                                    <td>@(log.UserRole ?? "N/A")</td>
                                    <td>@(log.IpAddress ?? "N/A")</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(log.ChangesJson))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#detailsModal_@log.Id">
                                                View Details
                                            </button>
                                            <!-- Modal for details -->
                                            <div class="modal fade" id="detailsModal_@log.Id" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Action Details</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <pre style="white-space: pre-wrap; word-wrap: break-word;">@log.ChangesJson</pre>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No details</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.RecordsTotal > itemsPerPage)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            @{
                                var totalPages = (int)Math.Ceiling((double)Model.RecordsTotal / itemsPerPage);
                                var startPage = Math.Max(1, currentPage - 2);
                                var endPage = Math.Min(totalPages, currentPage + 2);
                            }
                            
                            @if (currentPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("AuditLog", new { page = currentPage - 1, itemsPerPage = itemsPerPage, action = filter?.Action, entity = filter?.Entity, startDate = filter?.StartDate?.ToString("yyyy-MM-dd"), endDate = filter?.EndDate?.ToString("yyyy-MM-dd"), userName = filter?.UserName })">Previous</a>
                                </li>
                            }
                            
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("AuditLog", new { page = i, itemsPerPage = itemsPerPage, action = filter?.Action, entity = filter?.Entity, startDate = filter?.StartDate?.ToString("yyyy-MM-dd"), endDate = filter?.EndDate?.ToString("yyyy-MM-dd"), userName = filter?.UserName })">@i</a>
                                </li>
                            }
                            
                            @if (currentPage < totalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("AuditLog", new { page = currentPage + 1, itemsPerPage = itemsPerPage, action = filter?.Action, entity = filter?.Entity, startDate = filter?.StartDate?.ToString("yyyy-MM-dd"), endDate = filter?.EndDate?.ToString("yyyy-MM-dd"), userName = filter?.UserName })">Next</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }

                <div class="mt-3">
                    <small class="text-muted">Showing @((currentPage - 1) * itemsPerPage + 1) to @(Math.Min(currentPage * itemsPerPage, Model.RecordsTotal)) of @Model.RecordsTotal entries</small>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script src="~/select2/select2.full.min.js"></script>
    <script>
        $(document).ready(function() {
            // Initialize Select2 for username field
            $('#userName').select2({
                theme: 'bootstrap4',
                placeholder: 'Type to search user name...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                ajax: {
                    url: '@Url.Action("GetAuditLogUserNames", "Medicines")',
                    dataType: 'json',
                    delay: 250,
                    data: function (params) {
                        return {
                            search: params.term || '',
                            page: params.page || 1,
                            itemsPerPage: 50
                        };
                    },
                    processResults: function (response) {
                        return {
                            results: response.results || [],
                            pagination: {
                                more: response.pagination?.more || false
                            }
                        };
                    },
                    cache: false // Disable cache to ensure fresh results
                },
                minimumInputLength: 0 // Allow showing results even with no input
            });

            // Set initial value if exists
            @if (!string.IsNullOrWhiteSpace(filter?.UserName))
            {
                <text>
                var initialUserName = '@filter.UserName';
                var option = new Option(initialUserName, initialUserName, true, true);
                $('#userName').append(option).trigger('change');
                </text>
            }

            // Auto-update entity when action is selected
            $('#action').on('change', function() {
                var selectedAction = $(this).val();
                if (selectedAction === 'Dispensed' || selectedAction === 'Delete') {
                    // Dispensed and Delete actions are logged under MedicineTransaction
                    if ($('#entity').val() === '' || $('#entity').val() === 'Medicine') {
                        $('#entity').val('MedicineTransaction').trigger('change');
                    }
                }
            });

            // Show helpful message based on action/entity combination
            function updateEntityHint() {
                var action = $('#action').val();
                var entity = $('#entity').val();
                var hint = $('#entityHint');
                
                if (!hint.length) {
                    $('#entity').after('<small id="entityHint" class="text-muted d-block mt-1"></small>');
                    hint = $('#entityHint');
                }

                if (action === 'Dispensed' && entity === 'Medicine') {
                    hint.text('Note: Dispensed actions are logged under "Medicine Transaction" entity. Please select "Medicine Transaction" to see dispensed actions.');
                    hint.removeClass('text-muted').addClass('text-warning');
                } else if (action === 'Dispensed' && entity === 'MedicineTransaction') {
                    hint.text('✓ Correct: Dispensed actions are under Medicine Transaction entity.');
                    hint.removeClass('text-warning').addClass('text-success');
                } else {
                    hint.text('');
                }
            }

            $('#action, #entity').on('change', updateEntityHint);
            updateEntityHint(); // Run on page load
        });
    </script>
}

