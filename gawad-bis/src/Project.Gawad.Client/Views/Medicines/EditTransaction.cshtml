@model Project.Gawad.Domain.Objects.Medicine.UpdateMedicineTransactionObject
@{
    ViewData["Title"] = "Edit Stock-In Transaction";
    ViewData["HeaderTitle"] = "Edit Stock-In Transaction";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">Edit Stock-In Transaction</h3>
        </div>
        <form asp-action="EditTransaction" method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="TransactionId" />
                
                @if (ViewBag.MedicineName != null)
                {
                    <div class="alert alert-info">
                        <strong>Medicine:</strong> @ViewBag.MedicineName
                    </div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Quantity">Quantity</label>
                            <input asp-for="Quantity" class="form-control" type="number" step="0.01" min="0.01" />
                            <small class="form-text text-muted">Enter the corrected quantity. Stock will be adjusted automatically.</small>
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TransactionDate">Transaction Date</label>
                            <input asp-for="TransactionDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="TransactionDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="UnitPrice">Unit Price</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">₱</span>
                                </div>
                                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Reason">Reason</label>
                            <input asp-for="Reason" class="form-control" />
                            <span asp-validation-for="Reason" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Notes">Notes</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle"></i> <strong>Note:</strong> Changing the quantity will automatically adjust the stock inventory. 
                    If you increase the quantity, stock will be added. If you decrease it, stock will be deducted.
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Update Transaction</button>
                <a href="@Url.Action("Transactions")" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
}







