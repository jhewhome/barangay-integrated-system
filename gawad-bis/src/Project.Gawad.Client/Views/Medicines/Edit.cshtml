@model Project.Gawad.Domain.Objects.Medicine.UpdateMedicineObject
@using Project.Gawad.Core.Extensions
@{
    ViewData["Title"] = "Edit Medicine";
    ViewData["HeaderTitle"] = "Edit Medicine";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">Edit Medicine</h3>
        </div>
        <form asp-action="Edit" method="post">
            <div class="card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="MedicineId" />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group" style="position: relative;">
                            <label asp-for="Name">Medicine Name</label>
                            <input asp-for="Name" class="form-control" id="medicineNameInput" autocomplete="off" required />
                            <div id="medicineNameSuggestions"></div>
                            <span asp-validation-for="Name" class="text-danger"></span>
                            <div id="duplicateMedicineError" class="alert alert-danger mt-2" style="display: none;">
                                <i class="fas fa-exclamation-triangle"></i> <strong>Warning:</strong> This medicine name already exists in the system. You cannot use a duplicate medicine name.
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Category"></label>
                            <select asp-for="Category" class="form-control">
                                <option value="">-- Select Category --</option>
                                @foreach (Project.Gawad.Domain.Enums.Medicine.MedicineCategory cat in Enum.GetValues(typeof(Project.Gawad.Domain.Enums.Medicine.MedicineCategory)))
                                {
                                    if (Model.Category == cat)
                                    {
                                        <option value="@cat" selected>@cat.GetEnumDisplayName()</option>
                                    }
                                    else
                                    {
                                        <option value="@cat">@cat.GetEnumDisplayName()</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="UnitOfMeasure">Unit of Measure</label>
                            <select asp-for="UnitOfMeasure" class="form-control" id="unitOfMeasureSelect">
                                <option value="">-- Select Unit of Measure --</option>
                                <option value="@Project.Gawad.Domain.Enums.Medicine.UnitOfMeasure.Box">Box</option>
                                <option value="@Project.Gawad.Domain.Enums.Medicine.UnitOfMeasure.Bottle">Bottle</option>
                            </select>
                            <span asp-validation-for="UnitOfMeasure" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="UnitPrice">Unit Price</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">₱</span>
                                </div>
                                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <small class="form-text text-muted">
                                @{
                                    var isBoxUnit = Model.UnitOfMeasure == Project.Gawad.Domain.Enums.Medicine.UnitOfMeasure.Box;
                                }
                                @if (isBoxUnit)
                                {
                                    <span>Price per box</span>
                                }
                                else
                                {
                                    <span>Price per @Model.UnitOfMeasure.ToString().ToLower()</span>
                                }
                            </small>
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row" id="bottleMeasurementSection" style="display: @(Model.UnitOfMeasure == Project.Gawad.Domain.Enums.Medicine.UnitOfMeasure.Bottle ? "block" : "none");">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="BottleMeasurementType">Bottle Content Type</label>
                            <select asp-for="BottleMeasurementType" class="form-control" id="bottleMeasurementType">
                                <option value="">-- Select Type --</option>
                                <option value="mg">MG (Milligrams) - for capsules/tablets</option>
                                <option value="ml">ML (Milliliters) - for liquid</option>
                            </select>
                            <small class="form-text text-muted">Specify if the bottle contains capsules/tablets (MG) or liquid (ML)</small>
                            <span asp-validation-for="BottleMeasurementType" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="BottleMeasurementValue" id="bottleMeasurementValueLabel">Measurement Value</label>
                            <div class="input-group">
                                <input asp-for="BottleMeasurementValue" class="form-control" type="number" step="0.01" min="0.01" id="bottleMeasurementValue" />
                                <div class="input-group-append">
                                    <span class="input-group-text" id="bottleMeasurementUnit">mg/ml</span>
                                </div>
                            </div>
                            <small class="form-text text-muted">Enter the amount per bottle (e.g., 100, 200)</small>
                            <span asp-validation-for="BottleMeasurementValue" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="MinimumStockLevel">Minimum Stock Level</label>
                            <input asp-for="MinimumStockLevel" class="form-control" type="number" min="0" />
                            <span asp-validation-for="MinimumStockLevel" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Description">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                <button type="submit" class="btn btn-primary">Update</button>
                <a href="@Url.Action("Details", new { id = Model.MedicineId })" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script>
        window.currentMedicineId = '@Model.MedicineId';
    </script>
    <script src="~/app/js/medicines-edit.js"></script>
}


