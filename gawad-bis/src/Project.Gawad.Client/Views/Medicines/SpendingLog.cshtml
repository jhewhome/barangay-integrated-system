@model Project.Gawad.Domain.Objects.Medicine.ReportFilterObject
@{
    ViewData["Title"] = "Spending Log";
    ViewData["HeaderTitle"] = "Spending Log";
    var reportData = ViewBag.ReportData as IEnumerable<Project.Gawad.Domain.Objects.Medicine.MedicineSpendingLogObject>;
}

<form id="__antiForgeryForm" method="post" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">Filter</h3>
        </div>
        <form asp-action="SpendingLog" method="post">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="StartDate" class="form-label"></label>
                        <input asp-for="StartDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EndDate" class="form-label"></label>
                        <input asp-for="EndDate" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary">Generate</button>
                        @if (reportData != null)
                        {
                            <a class="btn btn-success" href="@Url.Action("ExportSpendingLog", new { StartDate = Model?.StartDate, EndDate = Model?.EndDate })">Export CSV</a>
                        }
                    </div>
                </div>
            </div>
        </form>
    </div>

    @if (reportData != null)
    {
        <div class="card card-primary card-outline mt-3">
            <div class="card-header">
                <h3 class="card-title">@ViewBag.ReportTitle</h3>
                <div class="card-tools"><small>Generated: @ViewBag.GeneratedDate</small></div>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Medicine</th>
                            <th>Supplier</th>
                            <th>Batch</th>
                            <th>Lot</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Unit Cost</th>
                            <th class="text-end">Total Cost</th>
                            <th>Received</th>
                            <th>Expiry</th>
                            @if (User.IsInRole("Administrator"))
                            {
                                <th class="text-center">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var i in reportData)
                    {
                        <tr data-stock-id="@(i.StockId?.ToString() ?? "")">
                            <td>@i.MedicineName</td>
                            <td>@i.Supplier</td>
                            <td>@i.BatchNumber</td>
                            <td>@i.LotNumber</td>
                            <td class="text-end">@i.Quantity</td>
                            <td class="text-end">@(i.UnitCost?.ToString("F2") ?? "-")</td>
                            <td class="text-end">@(i.TotalCost?.ToString("F2") ?? "-")</td>
                            <td>@(i.ReceivedDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                            <td>@(i.ExpiryDate?.ToString("MM/dd/yyyy") ?? "-")</td>
                            @if (User.IsInRole("Administrator") && i.StockId.HasValue)
                            {
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-danger delete-stock-btn" data-stock-id="@i.StockId.Value.ToString()" title="Delete Stock Record">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            }
                            else if (User.IsInRole("Administrator"))
                            {
                                <td class="text-center">-</td>
                            }
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script>
        $(document).ready(function() {
            // Handle delete stock button click
            $(document).on('click', '.delete-stock-btn', function() {
                var stockId = $(this).data('stock-id');
                var $row = $(this).closest('tr');
                
                if (!stockId) {
                    alert('Invalid stock ID');
                    return;
                }

                if (!confirm('Are you sure you want to delete this stock record? This action cannot be undone.')) {
                    return;
                }

                // Disable button during request
                var $btn = $(this);
                $btn.prop('disabled', true);

                // Get anti-forgery token
                var token = $('input[name="__RequestVerificationToken"]').val() || 
                           $('form#__antiForgeryForm input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("DeleteStock", "Medicines")',
                    type: 'POST',
                    data: {
                        id: stockId,
                        __RequestVerificationToken: token
                    },
                    success: function(response) {
                        if (response.success) {
                            // Remove the row from the table
                            $row.fadeOut(300, function() {
                                $(this).remove();
                                
                                // Check if table is empty
                                var colCount = $('thead th').length;
                                if ($('tbody tr').length === 0) {
                                    $('tbody').append('<tr><td colspan="' + colCount + '" class="text-center">No records found.</td></tr>');
                                }
                            });
                            
                            // Show success message
                            alert(response.message || 'Stock record deleted successfully.');
                        } else {
                            alert(response.message || 'Failed to delete stock record.');
                            $btn.prop('disabled', false);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error deleting stock:', error);
                        alert('An error occurred while deleting the stock record. Please try again.');
                        $btn.prop('disabled', false);
                    }
                });
            });
        });
    </script>
}

