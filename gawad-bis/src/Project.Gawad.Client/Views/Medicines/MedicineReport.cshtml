    }
    
    @@media print {
        /* Set page orientation to landscape */
        @@page {
            size: landscape;
            margin: 0.5in;
        }
        
        /* Large background logo watermark */
        body {
            position: relative;
        }
        
        body::before {
            content: "";
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 500px;
            height: 500px;
            background-image: url('@Url.Content("~/images/logo.png")');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            opacity: 0.08;
            z-index: -1;
            pointer-events: none;
        }
        
        /* Show print header and footer */
        .print-header,
        .print-footer {
            display: block !important;
        }
        
        /* Hide navigation and non-essential elements */
        .app-sidebar,
        .main-header,
        .app-footer,
        .app-content-header,
        .card-header,
        .card-header .btn,
        .card-header .card-tools,
        .btn,
        nav,
        .navbar {
            display: none !important;
        }
        
        /* Remove padding and margins for print */
        body {
            padding: 0 !important;
            margin: 0 !important;
        }
        
        .app-main {
            margin-left: 0 !important;
            padding: 0 !important;
        }
        
        .app-content {
            padding: 0 !important;
        }
        
        /* Optimize card styling for print */
        .card {
            border: none !important;
            box-shadow: none !important;
        }
        
        /* Keep print header and first content together on first page */
        .print-header + .col-12 .card-body {
            page-break-before: auto;
        }
        
        .card-body > .row:first-child {
            page-break-after: avoid;
        }
        
        /* Reduce spacing after print header */
        .print-header {
            margin-bottom: 5px !important;
            page-break-after: avoid;
        }
        
        .print-header .doc-header {
            margin-bottom: 5px !important;
            padding-bottom: 5px !important;
        }
        
        .card-header {
            border-bottom: 2px solid #000 !important;
            padding: 10px 0 !important;
            margin-bottom: 5px !important;
            page-break-after: avoid;
        }
        
        .card-body {
            padding: 0 !important;
            margin-top: 0 !important;
        }
        
        /* Ensure Medicine Details section appears on first page */
        .medicine-details-section {
            page-break-after: avoid;
            page-break-inside: avoid;
        }
        
        .medicine-details-section h4 {
            page-break-after: avoid;
            margin-top: 5px !important;
            margin-bottom: 5px !important;
        }
        
        .card-title {
            margin: 0 !important;
        }
        
        /* Reduce spacing after header - first row in card-body */
        .card-body > .row:first-child {
            margin-top: 0 !important;
            margin-bottom: 3px !important;
        }
        
        /* Reduce spacing for generated date paragraph */
        .card-body > .row:first-child p {
            margin-bottom: 0 !important;
        }
        
        /* Table optimizations */
        .table-responsive {
            overflow: visible !important;
        }
        
        table {
            page-break-inside: auto;
            border-collapse: collapse !important;
        }
        
        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }
        
        thead {
            display: table-header-group;
        }
        
        tfoot {
            display: table-footer-group;
        }
        
        th, td {
            border: 1px solid #ddd !important;
            padding: 8px !important;
        }
        
        /* Ensure badges are visible in print */
        .badge {
            border: 1px solid #000 !important;
            padding: 2px 6px !important;
        }
        
        /* Hide icons or make them minimal */
        .bi, i {
            display: none !important;
        }
        
        /* Optimize typography for print */
        h3, h4, h5 {
            page-break-after: avoid;
            margin-top: 15px !important;
            margin-bottom: 10px !important;
        }
        
        /* Page break control */
        .row {
            page-break-inside: avoid;
        }
        
        .mb-4, .mb-3 {
            margin-bottom: 15px !important;
        }
        
        /* Ensure colors print */
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
        }
        
        /* Remove background colors from alert boxes but keep borders */
        .alert {
            border: 1px solid #000 !important;
            background: white !important;
            color: #000 !important;
        }
    }
</style>

