        align-items: center;
        gap: 20px;
        margin-bottom: 10px;
    }
    
    .doc-logo-small {
        height: 70px;
        width: 70px;
        object-fit: contain;
    }
    
    .doc-logo-big {
        height: 90px;
        width: 90px;
        object-fit: contain;
    }
    
    .doc-header-text {
