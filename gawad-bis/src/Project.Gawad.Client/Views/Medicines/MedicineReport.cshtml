@using Project.Gawad.Domain.Enums.Medicine
@model Project.Gawad.Domain.Objects.Medicine.MedicineDetailObject
@{
    ViewData["Title"] = "Medicine Report";
    ViewData["HeaderTitle"] = $"Medicine Report: {Model.Name}";
    
    var stockBatches = ViewBag.StockBatches as List<Project.Gawad.Domain.Objects.Medicine.MedicineStockListObject> ?? new List<Project.Gawad.Domain.Objects.Medicine.MedicineStockListObject>();
    var transactions = ViewBag.Transactions as List<Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject> ?? new List<Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject>();
    var startDate = ViewBag.StartDate as DateTime?;
    var endDate = ViewBag.EndDate as DateTime?;
    var generatedDate = ViewBag.GeneratedDate as DateTime? ?? DateTime.Now;
}

@functions {
    // Helper function to parse unit type and count from Notes field
    string GetUnitTypeAndCount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        if (string.IsNullOrWhiteSpace(transaction.Notes))
            return null;

        var notes = transaction.Notes.Trim();
        
        // Check for INPUT_UNIT format: "INPUT_UNIT:boxes:2" or "INPUT_UNIT:bottles:5"
        if (notes.StartsWith("INPUT_UNIT:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var unitInfo = notes.Substring(11); // Remove "INPUT_UNIT:" prefix
                var unitInfoPart = unitInfo.Split(';')[0].Trim(); // Get first part if there are multiple sections
                var parts = unitInfoPart.Split(':');
                
                if (parts.Length >= 2)
                {
                    var unitType = parts[0].Trim().ToLower();
                    if (decimal.TryParse(parts[1].Trim(), out var unitCount) && unitCount > 0)
                    {
                        // Normalize unit type names
                        if (unitType == "boxes" || unitType == "box")
                            return $"{unitCount} box{(unitCount != 1 ? "es" : "")}";
                        else if (unitType == "bottles" || unitType == "bottle")
                            return $"{unitCount} bottle{(unitCount != 1 ? "s" : "")}";
                        else if (unitType == "pieces" || unitType == "piece")
                            return $"{unitCount} piece{(unitCount != 1 ? "s" : "")}";
                    }
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        // Check for BOXES format: "BOXES:2.5" (used in dispensed transactions)
        if (notes.StartsWith("BOXES:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var boxesStr = notes.Substring(6).Trim(); // Remove "BOXES:" prefix
                var boxInfoPart = boxesStr.Split(';')[0].Trim(); // Get first part if there are multiple sections
                if (decimal.TryParse(boxInfoPart, out var numberOfBoxes) && numberOfBoxes > 0)
                {
                    return $"{numberOfBoxes} box{(numberOfBoxes != 1 ? "es" : "")}";
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        return null;
    }
    
    // Helper function to calculate total amount correctly
    // Formula: Unit Price × Number of Boxes/Bottles (NOT quantity/pieces)
    decimal? GetCalculatedTotalAmount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        // If TotalAmount already exists, use it
        if (transaction.TotalAmount.HasValue)
            return transaction.TotalAmount;
        
        // If no unit price, can't calculate
        if (!transaction.UnitPrice.HasValue)
            return null;
        
        // Parse Notes to get unit type and count
        var unitTypeAndCount = GetUnitTypeAndCount(transaction);
        if (string.IsNullOrWhiteSpace(unitTypeAndCount))
            return null; // Can't calculate without unit info
        
        // Extract number from unitTypeAndCount (e.g., "2 boxes" -> 2)
        try
        {
            var parts = unitTypeAndCount.Split(' ');
            if (parts.Length >= 1 && decimal.TryParse(parts[0], out var unitCount))
            {
                // Formula: Unit Price × Number of Boxes/Bottles
                return transaction.UnitPrice.Value * unitCount;
            }
        }
        catch
        {
            // If parsing fails, return null
        }
        
        return null;
    }
}

<!-- Print-only header -->
<div class="print-header" style="display: none;">
    <div class="doc-header">
        <div class="doc-header-text">
            <div class="title-line title-top">REPUBLIC OF THE PHILIPPINES</div>
            <div class="title-line title-middle">CITY OF SAN JUAN</div>
            <div class="title-line title-main">BARANGAY BALONG BATO</div>
            <div style="font-size: 11px; margin-top: 5px;">
                <div>Tel. No. 8723-9561</div>
                <div>balongbato.sanjuan@gmail.com</div>
            </div>
        </div>
        <div class="doc-header-logos">
            <img src="@Url.Content("~/images/bagong.png")" alt="Bagong Pilipinas Logo" class="doc-logo-small" />
            <img src="@Url.Content("~/images/sjc.png")" alt="San Juan City Seal" class="doc-logo-small" />
            <img src="@Url.Content("~/images/logo.png")" alt="Barangay Balong Bato Seal" class="doc-logo-big" />
            <img src="@Url.Content("~/images/makabago.png")" alt="Makabagong San Juan Logo" class="doc-logo-small" />
        </div>
        <div class="doc-header-text">
            <div class="receipt-title">Medicine Comprehensive Report</div>
            <div class="medicine-report-title" style="margin-top: 10px; margin-bottom: 5px; font-size: 24px; font-weight: 800; letter-spacing: 0.5px;">
                Medicine Report: @Model.Name
            </div>
            <div style="margin-top: 5px; margin-bottom: 0; font-size: 11px;">
                <span>Generated: @generatedDate.ToString("MM/dd/yyyy HH:mm:ss")</span>
            </div>
        </div>
    </div>
</div>

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center w-100">
                <h3 class="card-title mb-0">@Model.Name - Comprehensive Report</h3>
                <div class="d-flex gap-2">
                    <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-sm btn-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Details
                    </a>
                    <a href="@Url.Action("ExportMedicineReport", new { id = Model.Id, startDate = startDate, endDate = endDate })" class="btn btn-sm btn-success">
                        <i class="bi bi-download"></i> Export CSV
                    </a>
                    <button type="button" class="btn btn-sm btn-primary" onclick="window.print()">
                        <i class="bi bi-printer"></i> Print
                    </button>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-md-12">
                    <p class="text-muted mb-0">
                        <strong>Generated:</strong> @generatedDate.ToString("MM/dd/yyyy HH:mm:ss") | 
                        <strong>Date Range:</strong> 
                        @if (startDate.HasValue && startDate.Value != DateTime.MinValue)
                        {
                            <text>@startDate.Value.ToString("MM/dd/yyyy")</text>
                        }
                        else
                        {
                            <text>All Time</text>
                        }
                        - 
                        @if (endDate.HasValue)
                        {
                            <text>@endDate.Value.ToString("MM/dd/yyyy")</text>
                        }
                        else
                        {
                            <text>Present</text>
                        }
                    </p>
                </div>
            </div>

            <!-- Medicine Details Section -->
            <div class="row mb-4 medicine-details-section">
                <div class="col-12">
                    <h4 class="mb-3"><i class="bi bi-info-circle"></i> Medicine Details</h4>
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tbody>
                                <tr>
                                    <th style="width: 200px;">Medicine Name</th>
                                    <td>@Model.Name</td>
                                    <th style="width: 200px;">Category</th>
                                    <td>@Model.CategoryName</td>
                                </tr>
                                <tr>
                                    <th>Unit of Measure</th>
                                    <td>@Model.UnitOfMeasure</td>
                                    <th>Current Stock</th>
                                    <td><strong>@Model.TotalStock</strong></td>
                                </tr>
                                <tr>
                                    <th>Minimum Stock Level</th>
                                    <td>@Model.MinimumStockLevel</td>
                                    <th>Unit Price</th>
                                    <td>@(Model.UnitPrice?.ToString("F2") ?? "N/A")</td>
                                </tr>
                                <tr>
                                    <th>Status</th>
                                    <td>
                                        @if (Model.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <th>Stock Status</th>
                                    <td>
                                        @if (Model.TotalStock <= Model.MinimumStockLevel)
                                        {
                                            <span class="badge bg-danger">Low Stock</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Adequate</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Statistics Summary Section -->
            @if (ViewBag.TotalTransactions != null)
            {
                <div class="row mb-4">
                    <div class="col-12">
                        <h4 class="mb-3"><i class="bi bi-graph-up"></i> Statistics Summary</h4>
                        <div class="row">
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="card-title text-muted mb-1">Total Dispensed</h5>
                                        <h3 class="mb-0">@(ViewBag.TotalDispensed ?? 0)</h3>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="card-title text-muted mb-1">Total Stock In</h5>
                                        <h3 class="mb-0">@(ViewBag.TotalStockIn ?? 0)</h3>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="card-title text-muted mb-1">Total Stock Out</h5>
                                        <h3 class="mb-0">@(ViewBag.TotalStockOut ?? 0)</h3>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-3">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="card-title text-muted mb-1">Total Value Dispensed</h5>
                                        <h3 class="mb-0">₱@((ViewBag.TotalDispensedValue ?? 0m).ToString("F2"))</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Stock Batches Section -->
            @if (stockBatches.Any())
            {
                <div class="row mb-4">
                    <div class="col-12">
                        <h4 class="mb-3"><i class="bi bi-box-seam"></i> Stock Batches</h4>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Batch Number</th>
                                        <th>Lot Number</th>
                                        <th class="text-end">Quantity</th>
                                        <th>Expiry Date</th>
                                        <th class="text-end">Days Until Expiry</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var stock in stockBatches.OrderBy(s => s.ExpiryDate ?? DateTime.MaxValue))
                                    {
                                        var daysUntilExpiry = stock.ExpiryDate.HasValue ? (stock.ExpiryDate.Value.Date - DateTime.Now.Date).Days : (int?)null;
                                        var statusBadge = stock.IsExpired ? "danger" : (stock.IsExpiringSoon ? "warning" : "success");
                                        var statusText = stock.IsExpired ? "Expired" : (stock.IsExpiringSoon ? "Expiring Soon" : "Active");
                                        
                                        <tr>
                                            <td>@(stock.BatchNumber ?? "N/A")</td>
                                            <td>@(stock.LotNumber ?? "N/A")</td>
                                            <td class="text-end">@stock.Quantity</td>
                                            <td>@(stock.ExpiryDate?.ToString("MM/dd/yyyy") ?? "N/A")</td>
                                            <td class="text-end">
                                                @if (daysUntilExpiry.HasValue)
                                                {
                                                    if (daysUntilExpiry.Value < 0)
                                                    {
                                                        <text>@Math.Abs(daysUntilExpiry.Value) days ago</text>
                                                    }
                                                    else
                                                    {
                                                        <text>@daysUntilExpiry.Value days</text>
                                                    }
                                                }
                                                else
                                                {
                                                    <text>-</text>
                                                }
                                            </td>
                                            <td><span class="badge bg-@statusBadge">@statusText</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Transaction History Section -->
            @if (transactions.Any())
            {
                <div class="row">
                    <div class="col-12">
                        <h4 class="mb-3"><i class="bi bi-clock-history"></i> Transaction History (@transactions.Count transactions)</h4>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th class="text-end">Quantity</th>
                                        <th class="text-end">Unit Price</th>
                                        <th class="text-end">Total Amount</th>
                                        <th>Recipient</th>
                                        <th>Reason</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in transactions)
                                    {
                                        var unitTypeAndCount = GetUnitTypeAndCount(t);
                                        <tr>
                                            <td>@t.TransactionDate.ToString("MM/dd/yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge bg-@(t.TransactionType == MedicineTransactionType.Dispensed ? "warning" : (t.TransactionType == MedicineTransactionType.StockIn ? "success" : "secondary"))">
                                                    @t.TransactionTypeName
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                @if (!string.IsNullOrEmpty(unitTypeAndCount))
                                                {
                                                    <div>@unitTypeAndCount</div>
                                                    <small class="text-muted">(@t.Quantity.ToString("N0") pieces)</small>
                                                }
                                                else
                                                {
                                                    @t.Quantity.ToString("N0") <small class="text-muted">pieces</small>
                                                }
                                            </td>
                                            <td class="text-end">@(t.UnitPrice?.ToString("N2") ?? "-")</td>
                                            <td class="text-end">
                                                @{
                                                    var calculatedTotal = GetCalculatedTotalAmount(t);
                                                    if (calculatedTotal.HasValue)
                                                    {
                                                        <text>@calculatedTotal.Value.ToString("N2")</text>
                                                    }
                                                    else
                                                    {
                                                        <text>-</text>
                                                    }
                                                }
                                            </td>
                                            <td>@(t.RecipientName ?? "-")</td>
                                            <td>@(t.Reason ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> No transactions found for the selected date range.
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Print-only footer -->
<div class="print-footer" style="display: none;">
    <div class="receipt-footer">
        <div>Note: This report was generated by the Barangay Health Office Medicine Management System.</div>
        <div style="margin-top: 5px;">Page generated on @DateTime.Now.ToString("MM/dd/yyyy HH:mm:ss")</div>
    </div>
</div>

