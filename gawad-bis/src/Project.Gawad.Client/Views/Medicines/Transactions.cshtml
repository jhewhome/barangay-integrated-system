            size: landscape;
            margin: 0.5in;
        }
        
        /* Large background logo watermark */
        body {
            position: relative;
        }
        
        body::before {
            content: "";
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 500px;
            height: 500px;
            background-image: url('@Url.Content("~/images/logo.png")');
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            opacity: 0.08;
            z-index: -1;
            pointer-events: none;
        }
        
        /* Show print header and footer */
