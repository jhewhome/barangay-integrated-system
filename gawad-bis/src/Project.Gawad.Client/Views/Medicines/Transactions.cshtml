@model Project.Gawad.Domain.Objects.PaginatedRecords<Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject>
@{
    ViewData["Title"] = "Transactions";
    ViewData["HeaderTitle"] = "Medicine Transactions";
    var medicineId = Context.Request.Query["medicineId"].ToString();
    var generatedDate = DateTime.Now;
}

@section StyleSheets
{
    <link type="text/css" rel="stylesheet" href="~/select2/select2.min.css"/>
    <link type="text/css" rel="stylesheet" href="~/select2/select2-bootstrap4.min.css"/>
}

@functions {
    // Helper function to parse unit type and count from Notes field
    string GetUnitTypeAndCount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        if (string.IsNullOrWhiteSpace(transaction.Notes))
            return null;

        var notes = transaction.Notes.Trim();
        
        // Check for INPUT_UNIT format: "INPUT_UNIT:boxes:2" or "INPUT_UNIT:bottles:5"
        if (notes.StartsWith("INPUT_UNIT:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var unitInfo = notes.Substring(11); // Remove "INPUT_UNIT:" prefix
                var unitInfoPart = unitInfo.Split(';')[0].Trim(); // Get first part if there are multiple sections
                var parts = unitInfoPart.Split(':');
                
                if (parts.Length >= 2)
                {
                    var unitType = parts[0].Trim().ToLower();
                    if (decimal.TryParse(parts[1].Trim(), out var unitCount) && unitCount > 0)
                    {
                        // Normalize unit type names
                        if (unitType == "boxes" || unitType == "box")
                            return $"{unitCount} box{(unitCount != 1 ? "es" : "")}";
                        else if (unitType == "bottles" || unitType == "bottle")
                            return $"{unitCount} bottle{(unitCount != 1 ? "s" : "")}";
                        else if (unitType == "pieces" || unitType == "piece")
                            return $"{unitCount} piece{(unitCount != 1 ? "s" : "")}";
                    }
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        // Check for BOXES format: "BOXES:2.5" (used in dispensed transactions)
        if (notes.StartsWith("BOXES:", StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                var boxesStr = notes.Substring(6).Trim(); // Remove "BOXES:" prefix
                var boxInfoPart = boxesStr.Split(';')[0].Trim(); // Get first part if there are multiple sections
                if (decimal.TryParse(boxInfoPart, out var numberOfBoxes) && numberOfBoxes > 0)
                {
                    return $"{numberOfBoxes} box{(numberOfBoxes != 1 ? "es" : "")}";
                }
            }
            catch
            {
                // If parsing fails, return null
            }
        }
        
        return null;
    }
    
    // Helper function to calculate total amount correctly
    // Formula: Unit Price × Number of Boxes/Bottles (NOT quantity/pieces)
    decimal? GetCalculatedTotalAmount(Project.Gawad.Domain.Objects.Medicine.MedicineTransactionListObject transaction)
    {
        // If TotalAmount already exists, use it
        if (transaction.TotalAmount.HasValue)
            return transaction.TotalAmount;
        
        // If no unit price, can't calculate
        if (!transaction.UnitPrice.HasValue)
            return null;
        
        // Parse Notes to get unit type and count
        var unitTypeAndCount = GetUnitTypeAndCount(transaction);
        if (string.IsNullOrWhiteSpace(unitTypeAndCount))
            return null; // Can't calculate without unit info
        
        // Extract number from unitTypeAndCount (e.g., "2 boxes" -> 2)
        try
        {
            var parts = unitTypeAndCount.Split(' ');
            if (parts.Length >= 1 && decimal.TryParse(parts[0], out var unitCount))
            {
                // Formula: Unit Price × Number of Boxes/Bottles
                return transaction.UnitPrice.Value * unitCount;
            }
        }
        catch
        {
            // If parsing fails, return null
        }
        
        return null;
    }
}

<!-- Print-only header -->
<div class="print-header" style="display: none;">
    <div class="doc-header">
        <div class="doc-header-text">
            <div class="title-line title-top">REPUBLIC OF THE PHILIPPINES</div>
            <div class="title-line title-middle">CITY OF SAN JUAN</div>
            <div class="title-line title-main">BARANGAY BALONG BATO</div>
            <div style="font-size: 11px; margin-top: 5px;">
                <div>Tel. No. 8723-9561</div>
                <div>balongbato.sanjuan@gmail.com</div>
            </div>
        </div>
        <div class="doc-header-logos">
            <img src="@Url.Content("~/images/bagong.png")" alt="Bagong Pilipinas Logo" class="doc-logo-small" />
            <img src="@Url.Content("~/images/sjc.png")" alt="San Juan City Seal" class="doc-logo-small" />
            <img src="@Url.Content("~/images/logo.png")" alt="Barangay Balong Bato Seal" class="doc-logo-big" />
            <img src="@Url.Content("~/images/makabago.png")" alt="Makabagong San Juan Logo" class="doc-logo-small" />
        </div>
        <div class="doc-header-text">
            <div class="receipt-title">Medicine Transaction Details</div>
            <div style="margin-top: 5px; margin-bottom: 0; font-size: 11px;">
                <span>Generated: @generatedDate.ToString("MM/dd/yyyy HH:mm:ss")</span>
            </div>
        </div>
    </div>
</div>

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center w-100">
                <h3 class="card-title mb-0">Medicine Transactions</h3>
            </div>
        </div>
        <!-- Search Filter Section -->
        <div class="card-body border-bottom">
            @{
                var selectedTransactionType = ViewBag.TransactionType as string ?? string.Empty;
            }
            <form method="get" action="@Url.Action("Transactions")" class="row g-3" id="filterForm">
                <input type="hidden" name="medicineId" value="@medicineId" />
                <div class="col-md-4">
                    <label for="search" class="form-label">Search (Medicine or Recipient Name)</label>
                    <select id="search" class="form-control select2bs4" style="width: 100%;" data-placeholder="Type to search medicine or recipient name...">
                        @if (!string.IsNullOrWhiteSpace(ViewBag.Search as string))
                        {
                            <option value="@ViewBag.Search" selected>@ViewBag.Search</option>
                        }
                    </select>
                    <input type="hidden" id="searchValue" name="search" value="@ViewBag.Search" />
                </div>
                <div class="col-md-2">
                    <label for="transactionType" class="form-label">Transaction Type</label>
                    <select class="form-control" id="transactionType" name="transactionType">
                        <option value="">All Types</option>
                        @if (selectedTransactionType == "StockIn")
                        {
                            <option value="StockIn" selected>Stock In</option>
                        }
                        else
                        {
                            <option value="StockIn">Stock In</option>
                        }
                        @if (selectedTransactionType == "Dispensed")
                        {
                            <option value="Dispensed" selected>Dispensed</option>
                        }
                        else
                        {
                            <option value="Dispensed">Dispensed</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="startDate" class="form-label">Start Date</label>
                    <input type="date" class="form-control" id="startDate" name="startDate" value="@ViewBag.StartDate" />
                </div>
                <div class="col-md-2">
                    <label for="endDate" class="form-label">End Date</label>
                    <input type="date" class="form-control" id="endDate" name="endDate" value="@ViewBag.EndDate" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Filter
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(ViewBag.Search) || !string.IsNullOrWhiteSpace(ViewBag.TransactionType) || 
                     !string.IsNullOrWhiteSpace(ViewBag.StartDate) || !string.IsNullOrWhiteSpace(ViewBag.EndDate))
                {
                    <div class="col-md-12">
                        <a href="@Url.Action("Transactions", new { medicineId = medicineId })" class="btn btn-sm btn-secondary">
                            <i class="bi bi-x-circle"></i> Clear Filters
                        </a>
                    </div>
                }
            </form>
        </div>
        <div class="card-body table-responsive">
            @if (Model == null || Model.Data == null || !Model.Data.Any())
            {
                <div class="alert alert-info mb-0">No transactions found.</div>
            }
            else
            {
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Medicine</th>
                            <th>Type</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end">Total</th>
                            <th>Recipient</th>
                            <th>Processed By</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var t in Model.Data)
                    {
                        var unitTypeAndCount = GetUnitTypeAndCount(t);
                        <tr>
                            <td>@t.TransactionDate.ToString("MM/dd/yyyy HH:mm")</td>
                            <td>@t.MedicineName</td>
                            <td><span class="badge bg-secondary">@t.TransactionTypeName</span></td>
                            <td class="text-end">
                                @if (!string.IsNullOrEmpty(unitTypeAndCount))
                                {
                                    <div>@unitTypeAndCount</div>
                                    <small class="text-muted">(@t.Quantity.ToString("N0") pieces)</small>
                                }
                                else
                                {
                                    @t.Quantity.ToString("N0") <small class="text-muted">pieces</small>
                                }
                            </td>
                            <td class="text-end">@(t.UnitPrice.HasValue ? t.UnitPrice.Value.ToString("N2") : "-")</td>
                            <td class="text-end">
                                @{
                                    var calculatedTotal = GetCalculatedTotalAmount(t);
                                    if (calculatedTotal.HasValue)
                                    {
                                        <text>@calculatedTotal.Value.ToString("N2")</text>
                                    }
                                    else
                                    {
                                        <text>-</text>
                                    }
                                }
                            </td>
                            <td>@(t.RecipientName ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(t.CreatedByName))
                                {
                                    <div class="d-flex flex-column">
                                        <span>@t.CreatedByName</span>
                                        @if (!string.IsNullOrWhiteSpace(t.CreatedByRole))
                                        {
                                            <small class="text-muted badge bg-light text-dark">@t.CreatedByRole</small>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group" role="group">
                                    @if (t.TransactionType == Project.Gawad.Domain.Enums.Medicine.MedicineTransactionType.StockIn)
                                    {
                                        <a class="btn btn-sm btn-outline-info" href="@Url.Action("EditTransaction", new { id = t.Id })" title="Edit Stock-In Transaction">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                    }
                                    @if (t.TransactionType == Project.Gawad.Domain.Enums.Medicine.MedicineTransactionType.Dispensed)
                                    {
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Receipt", new { id = t.Id })" title="View Receipt">
                                            <i class="bi bi-receipt"></i> Receipt
                                        </a>
                                    }
                                    @if (User.IsInRole("Administrator"))
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger delete-transaction-btn" 
                                                data-transaction-id="@t.Id" 
                                                data-transaction-type="@t.TransactionTypeName"
                                                data-transaction-date="@t.TransactionDate.ToString("MM/dd/yyyy HH:mm")"
                                                title="Delete Transaction (Admin Only)">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
        @if (Model != null && Model.PageSize > 0 && Model.RecordsTotal > Model.PageSize)
        {
            var totalPages = (int)Math.Ceiling((double)Model.RecordsTotal / Model.PageSize);
            var currentPage = Model.PageNumber;
            
            // Calculate page range to show (show max 7 page numbers)
            var startPage = Math.Max(1, currentPage - 3);
            var endPage = Math.Min(totalPages, currentPage + 3);
            
            // Adjust if we're near the beginning or end
            if (endPage - startPage < 6)
            {
                if (startPage == 1)
                    endPage = Math.Min(totalPages, startPage + 6);
                else if (endPage == totalPages)
                    startPage = Math.Max(1, endPage - 6);
            }
            
            <div class="card-footer">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <small>Page @currentPage of @totalPages (@Model.RecordsTotal total records)</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            @* Previous button *@
                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                @if (currentPage > 1)
                                {
                                    <a class="page-link" href="@Url.Action("Transactions", new { page = currentPage - 1, medicineId = !string.IsNullOrEmpty(medicineId) ? medicineId : null, search = ViewBag.Search, transactionType = ViewBag.TransactionType, recipientName = ViewBag.RecipientName, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })">Previous</a>
                                }
                                else
                                {
                                    <span class="page-link">Previous</span>
                                }
                            </li>
                            
                            @* First page button *@
                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Transactions", new { page = 1, medicineId = !string.IsNullOrEmpty(medicineId) ? medicineId : null, search = ViewBag.Search, transactionType = ViewBag.TransactionType, recipientName = ViewBag.RecipientName, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                            }
                            
                            @* Page number buttons *@
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                var pageNum = i;
                                <li class="page-item @(pageNum == currentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Transactions", new { page = pageNum, medicineId = !string.IsNullOrEmpty(medicineId) ? medicineId : null, search = ViewBag.Search, transactionType = ViewBag.TransactionType, recipientName = ViewBag.RecipientName, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })">@pageNum</a>
                                </li>
                            }
                            
                            @* Last page button *@
                            @if (endPage < totalPages)
                            {
                                @if (endPage < totalPages - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Transactions", new { page = totalPages, medicineId = !string.IsNullOrEmpty(medicineId) ? medicineId : null, search = ViewBag.Search, transactionType = ViewBag.TransactionType, recipientName = ViewBag.RecipientName, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })">@totalPages</a>
                                </li>
                            }
                            
                            @* Next button *@
                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                @if (currentPage < totalPages)
                                {
                                    <a class="page-link" href="@Url.Action("Transactions", new { page = currentPage + 1, medicineId = !string.IsNullOrEmpty(medicineId) ? medicineId : null, search = ViewBag.Search, transactionType = ViewBag.TransactionType, recipientName = ViewBag.RecipientName, startDate = ViewBag.StartDate, endDate = ViewBag.EndDate })">Next</a>
                                }
                                else
                                {
                                    <span class="page-link">Next</span>
                                }
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</div>

<!-- Print-only footer -->
