        /* Remove background colors from alert boxes but keep borders */
        .alert {
            border: 1px solid #000 !important;
            background: white !important;
            color: #000 !important;
        }
    }
</style>

@section Scripts
{
    <script src="~/bootstrap-datatables/jquery-3.7.1.js"></script>
    <script src="~/select2/select2.full.min.js"></script>
    <script>
        $(document).ready(function() {
            // Initialize Select2 for search field (medicine or recipient names)
            $('#search').select2({
                theme: 'bootstrap4',
                placeholder: 'Type to search medicine or recipient name...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('body'),
                language: {
                    searching: function() {
                        return 'Searching...';
                    },
                    noResults: function() {
                        return 'No results found';
                    }
                },
                ajax: {
                    delay: 250,
                    data: function (params) {
                        return {
                            search: params.term || '',
                            page: params.page || 1
                        };
                    },
                    transport: function (params, success, failure) {
                        var term = params.data.search || '';
                        if (!term || term.length < 1) {
                            success({ results: [], pagination: { more: false } });
                            return;
                        }

                        // Fetch both medicines and residents
                        var medicineRequest = $.getJSON('/Medicines/GetMedicinesList', {
                            search: term,
                            page: 1,
                            itemsPerPage: 10,
                            sortColIndex: 0,
                            sortColDir: 'asc'
                        });

                        var residentRequest = $.getJSON('/Residents/GetResidentsList', {
                            search: term,
                            page: 1,
                            itemsPerPage: 10,
                            sortColIndex: 0,
                            sortColDir: 'asc'
                        });

                        $.when(medicineRequest, residentRequest).done(function(medicineRes, residentRes) {
                            var results = [];
                            var resultsMap = new Map();
                            
                            // Process medicine results
                            var medicineData = medicineRes[0].data || medicineRes[0].Data || [];
                            medicineData.forEach(function(m) {
                                var name = (m.name || m.Name || '').trim();
                                if (name && !resultsMap.has(name.toLowerCase())) {
                                    resultsMap.set(name.toLowerCase(), name);
                                    results.push({
                                        id: name,
                                        text: name,
                                        type: 'medicine'
                                    });
                                }
                            });

                            // Process resident results
                            var residentData = residentRes[0].data || residentRes[0].Data || [];
                            residentData.forEach(function(r) {
                                var name = (r.name || r.Name || '').trim();
                                if (name && !resultsMap.has(name.toLowerCase())) {
                                    resultsMap.set(name.toLowerCase(), name);
                                    results.push({
                                        id: name,
                                        text: name,
                                        type: 'recipient'
                                    });
                                }
                            });

                            success({
                                results: results,
                                pagination: {
                                    more: false
                                }
                            });
                        }).fail(function() {
                            failure();
                        });
                    },
                    processResults: function (data) {
                        return data;
                    },
                    cache: false
                },
                minimumInputLength: 1
            });

            // Update hidden input when selection changes
            $('#search').on('select2:select', function(e) {
                var selectedValue = e.params.data.id;
                $('#searchValue').val(selectedValue);
            });

            // Clear hidden input and auto-submit form when search is cleared
            $('#search').on('select2:clear', function(e) {
                $('#searchValue').val('');
                // Auto-submit form to clear filter and show all results
                $('#filterForm').submit();
            });


            // Ensure form submission uses hidden input values
            $('#filterForm').on('submit', function(e) {
                // Update hidden input from Select2 value before submission
                var searchValue = $('#search').val();
                
                if (searchValue) {
                    $('#searchValue').val(searchValue);
                } else {
                    $('#searchValue').val('');
                }
            });

            // Delete transaction handler
            $(document).on('click', '.delete-transaction-btn', function(e) {
                e.preventDefault();
                var $btn = $(this);
                var transactionId = $btn.data('transaction-id');
                var transactionType = $btn.data('transaction-type');
                var transactionDate = $btn.data('transaction-date');
                
                // Confirm deletion
                if (!confirm('Are you sure you want to delete this transaction?\n\n' +
                           'Transaction Type: ' + transactionType + '\n' +
                           'Date: ' + transactionDate + '\n\n' +
                           'This action will reverse the stock change and cannot be undone.')) {
                    return;
                }
                
                // Disable button and show loading state
                $btn.prop('disabled', true).html('<i class="bi bi-hourglass-split"></i> Deleting...');
                
                // Make AJAX call to delete transaction
                $.ajax({
                    url: '@Url.Action("DeleteTransaction", "Medicines")',
                    type: 'POST',
                    data: { 
                        id: transactionId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response && response.success) {
                            // Show success message
                            alert('Transaction deleted successfully. Stock has been adjusted.');
                            // Reload the page to refresh the transaction list
                            location.reload();
                        } else {
                            // Show error message
                            var errorMsg = response && response.message ? response.message : 'Failed to delete transaction.';
                            alert('Error: ' + errorMsg);
                            // Re-enable button
                            $btn.prop('disabled', false).html('<i class="bi bi-trash"></i> Delete');
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error deleting transaction:', error, xhr);
                        var errorMsg = 'An error occurred while deleting the transaction.';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            errorMsg = xhr.responseJSON.message;
                        } else if (xhr.responseText) {
                            try {
                                var errorResponse = JSON.parse(xhr.responseText);
                                if (errorResponse.message) {
                                    errorMsg = errorResponse.message;
                                }
                            } catch (e) {
                                // If parsing fails, use default message
                            }
                        }
                        alert(errorMsg);
                        // Re-enable button
                        $btn.prop('disabled', false).html('<i class="bi bi-trash"></i> Delete');
                    }
                });
            });
        });
    </script>
}

