@model Project.Gawad.Domain.Objects.PaginatedRecords<Project.Gawad.Domain.Objects.Sales.SaleListObject>
@{
    ViewData["Title"] = "Sales";
    ViewData["HeaderTitle"] = "Sales List";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <div class="row g-2 align-items-center">
                <div class="col-lg-8 col-md-6">
                    <h3 class="card-title">Sales</h3>
                </div>
                <div class="col-lg-4 col-md-6 d-flex gap-2 justify-content-end">
                    <a href="@Url.ActionLink("Create")" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> New Sale
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            @if (Model == null || !Model.Data.Any())
            {
                <div class="alert alert-info mb-0">No sales found.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Customer</th>
                                <th class="text-end">Total Amount</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var sale in Model.Data)
                        {
                            <tr>
                                <td>@sale.SaleDate.ToString("MM/dd/yyyy HH:mm")</td>
                                <td>@(sale.CustomerName ?? "Walk-in")</td>
                                <td class="text-end">@sale.TotalAmount.ToString("F2")</td>
                                <td>
                                    <span class="badge bg-@(sale.Status == Project.Gawad.Domain.Enums.Sales.SaleStatus.Completed ? "success" : sale.Status == Project.Gawad.Domain.Enums.Sales.SaleStatus.Cancelled ? "danger" : "warning")">
                                        @sale.StatusName
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Details", new { id = sale.Id })" title="Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>



