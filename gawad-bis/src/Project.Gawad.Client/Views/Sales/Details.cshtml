@model Project.Gawad.Domain.Objects.Sales.SaleDetailObject
@{
    ViewData["Title"] = "Sale Details";
    ViewData["HeaderTitle"] = "Sale Details";
}

<div class="col-12">
    <div class="card card-primary card-outline">
        <div class="card-header">
            <h3 class="card-title">Sale Details</h3>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Sale Date</dt>
                <dd class="col-sm-9">@Model.SaleDate.ToString("MM/dd/yyyy HH:mm")</dd>
                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-@(Model.Status == Project.Gawad.Domain.Enums.Sales.SaleStatus.Completed ? "success" : Model.Status == Project.Gawad.Domain.Enums.Sales.SaleStatus.Cancelled ? "danger" : "warning")">
                        @Model.StatusName
                    </span>
                </dd>
                <dt class="col-sm-3">Customer</dt>
                <dd class="col-sm-9">@(Model.CustomerName ?? "Walk-in")</dd>
                <dt class="col-sm-3">Subtotal</dt>
                <dd class="col-sm-9">@Model.Subtotal.ToString("F2")</dd>
                <dt class="col-sm-3">Discount</dt>
                <dd class="col-sm-9">@Model.DiscountAmount.ToString("F2")</dd>
                <dt class="col-sm-3">Tax</dt>
                <dd class="col-sm-9">@Model.TaxAmount.ToString("F2")</dd>
                <dt class="col-sm-3">Total Amount</dt>
                <dd class="col-sm-9"><strong>@Model.TotalAmount.ToString("F2")</strong></dd>
                <dt class="col-sm-3">Amount Paid</dt>
                <dd class="col-sm-9">@Model.AmountPaid.ToString("F2")</dd>
                <dt class="col-sm-3">Change</dt>
                <dd class="col-sm-9">@Model.Change.ToString("F2")</dd>
            </dl>
            @if (Model.Status != Project.Gawad.Domain.Enums.Sales.SaleStatus.Completed)
            {
                <div class="mt-3">
                    <a href="@Url.Action("Payment", new { saleId = Model.Id })" class="btn btn-primary">
                        <i class="bi bi-credit-card"></i> Process Payment
                    </a>
                </div>
            }
        </div>
    </div>
</div>
