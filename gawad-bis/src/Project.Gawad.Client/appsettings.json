{
  "ConnectionStrings": {
    "DefaultConnection": "mongodb://127.0.0.1:27017/gawad"
  },
  "MongoDB": {
    "ConnectionString": "mongodb://127.0.0.1:27017",
    "GawadDatabaseName": "gawad_db",
    "IdentityDatabaseName": "gawad_identity"
  },
  "CookieConfig": {
    "ExpirationHours": 8,
    "SlidingExpiration": true
  },
  "AppConfig": {
    "AppName": "Gawad",
    "AppShortName": "Gawad",
    "Version": "1.0.0.0",
    "Variant": ""
  },
  "DefaultBarangayAddress": {
    "Barangay": "Barangay Balong-Bato",
    "City": "San Juan City",
    "ZipCode": "1500",
    "Province": "Metro Manila",
    "Country": "Philippines"
  },
  "OfficialSignatory": {
    "SignatoryName": "Alvin G. Alonzo",
    "SignatoryPosition": "Barangay Captain",
    "SignaturePath": "uploads/signatures/official_signature.png"
  },
  "VerificationUrl": {
    "BaseUrl": ""
  },
  "BhcIntegration": {
    "Enabled": true,
    "BaseUrl": "http://localhost/bhc_system/public",
    "OpenInNewTab": true,
    "ResidentSyncEnabled": true,
    "MedicineSyncEnabled": true,
    "IntegrationApiKey": "balong-bato-dev-integration-key",
    "SsoEnabled": true,
    "SsoSecret": "balong-bato-dev-sso-secret",
    "SsoTokenLifetimeSeconds": 300
  },
  "TemplatesConfig": {
    "Templates": [
      {
        "type": "BarangayClearance",
        "fileTemplatePath": "templates/barangayclearance.docx",
        "name": "Barangay Clearance"
      },
      {
        "type": "BarangayId",
        "fileTemplatePath": "templates/BarangayId.docx",
        "name": "Barangay Id"
      },
      {
        "type": "BusinessPermit",
        "fileTemplatePath": "templates/businesspermit.docx",
        "name": "Business Permit"
      },
      {
        "type": "CertificateOfIndigency",
        "fileTemplatePath": "templates/certificateofindigency.docx",
        "name": "Certificate of Indigency"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}